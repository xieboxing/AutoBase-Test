# ===== AI 模型配置 =====
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# ===== Appium 配置 =====
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
ANDROID_HOME=

# ===== 通知配置 =====
NOTIFY_EMAIL=
NOTIFY_WEBHOOK=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ===== 代理配置 =====
HTTP_PROXY=
HTTPS_PROXY=

# ===== 测试账号 =====
TEST_USERNAME=
TEST_PASSWORD=
API_TOKEN=

# ===== 存储配置 =====
DATA_DIR=./data
MAX_SCREENSHOTS=1000
MAX_REPORTS=50

# ===== 视觉回归配置 =====
VISUAL_BASELINE_DIR=./data/baselines
VISUAL_DIFF_THRESHOLD=0.01

# ===== 并发执行配置 =====
PARALLEL_WORKERS=auto

# ===== RAG 记忆配置 =====
RAG_ENABLED=true
RAG_MAX_MEMORIES=10000

# ===== 探索式测试配置 =====
EXPLORATION_MAX_STEPS=100
EXPLORATION_MAX_DURATION=1800
EXPLORATION_STRATEGY=reward-based