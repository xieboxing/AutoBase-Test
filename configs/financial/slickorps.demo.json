      "criticalElements": [
        {
          "strategy": "xpath",
          "value": "//android.widget.EditText[@hint='用户名']",
          "description": "用户名输入框"
        },
        {
          "strategy": "xpath",
          "value": "//android.widget.EditText[@hint='密码']",
