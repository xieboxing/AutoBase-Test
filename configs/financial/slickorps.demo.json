{
  "version": "1.0.0",
  "app": {
    "appName": "Slickorps",
    "packageName": "com.slickorps.app",
    "launchActivity": ".MainActivity",
    "platform": "android",
    "apkPath": "./slickorps.apk"
  },
  "login": {
    "required": true,
    "usernameLocator": {
      "strategy": "xpath",
      "value": "//android.widget.EditText[@hint='用户名' or @hint='账号' or @text='请输入用户名']",
      "description": "用户名输入框（待补充实际定位器）",
      "fallback": [
        {
          "strategy": "id",
          "value": "username_input",
          "description": "用户名输入框 ID 定位"
        }
      ]
    },
    "passwordLocator": {
      "strategy": "xpath",
      "value": "//android.widget.EditText[@hint='密码' or @text='请输入密码']",
      "description": "密码输入框（待补充实际定位器）",
      "fallback": [
        {
          "strategy": "id",
          "value": "password_input",
          "description": "密码输入框 ID 定位"
        }
      ]
    },
    "loginButtonLocator": {
      "strategy": "xpath",
      "value": "//android.widget.Button[contains(@text, '登录') or contains(@text, 'Login')]",
      "description": "登录按钮（待补充实际定位器）",
      "fallback": [
        {
          "strategy": "id",
          "value": "login_button",
          "description": "登录按钮 ID 定位"
        }
      ]
    },
    "successIndicator": {
      "strategy": "xpath",
      "value": "//android.widget.TextView[contains(@text, '首页') or contains(@text, 'Home') or contains(@text, '持仓')]",
      "description": "登录成功指示元素（待补充实际定位器）",
      "fallback": [
        {
          "strategy": "id",
          "value": "home_title",
          "description": "首页标题 ID 定位"
        }
      ]
    },
    "failureIndicator": {
      "strategy": "xpath",
      "value": "//android.widget.TextView[contains(@text, '错误') or contains(@text, '失败') or contains(@text, 'Error')]",
      "description": "登录失败提示元素（可选）"
    },
    "usernameEnvKey": "SLICKORPS_USERNAME",
    "passwordEnvKey": "SLICKORPS_PASSWORD",
    "timeout": 30000,
    "waitBefore": 2000,
    "waitAfter": 3000
  },
  "pages": [
    {
      "id": "login",
      "name": "登录页面",
